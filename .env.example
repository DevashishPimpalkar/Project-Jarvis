# ============================================================
#  JARVIS — Environment Configuration
#  Copy this file to .env and fill in your actual credentials.
#  NEVER commit .env to source control.
# ============================================================

# ─── Wake word ───────────────────────────────────────────────
WAKE_WORD=jarvis
WAKE_WORD_TIMEOUT=3
COMMAND_TIMEOUT=5
PHRASE_LIMIT=10

# ─── Speech recognition ──────────────────────────────────────
# Options: google | sphinx | whisper
STT_ENGINE=google
# Only used when STT_ENGINE=whisper:
WHISPER_MODEL=base
# Set to the device index of your preferred microphone (optional):
# MIC_DEVICE_INDEX=0

# ─── Text-to-speech ──────────────────────────────────────────
TTS_RATE=165
TTS_VOLUME=0.9
TTS_VOICE_INDEX=0

# ─── NLP / Intent parsing ────────────────────────────────────
# Options: spacy (local) | openai | grok
PARSER_BACKEND=spacy
SPACY_MODEL=en_core_web_sm

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Grok (xAI) ──────────────────────────────────────────────
GROK_API_KEY=xai-...
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-beta

# ─── Spotify ─────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ─── Weather (OpenWeatherMap) ────────────────────────────────
# Free key at https://openweathermap.org/api
WEATHER_API_KEY=your_owm_key_here
DEFAULT_CITY=New York

# ─── Browser ─────────────────────────────────────────────────
# Leave empty to use the system default browser
DEFAULT_BROWSER=
DEFAULT_SEARCH_ENGINE=https://www.google.com/search?q=

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
# Uncomment to also write logs to a file:
# LOG_FILE=jarvis.log

# ─── Startup ─────────────────────────────────────────────────
STARTUP_MESSAGE=All systems online. How can I help you?
